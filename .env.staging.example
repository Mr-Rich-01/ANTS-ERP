# ANTS ERP - staging environment template
# Copy to `.env.staging` and fill with staging-only values. Never commit `.env.staging`.

# ---------- Required: runtime ----------
NODE_ENV=production
APP_URL=http://localhost:3001
AUTH_URL=http://localhost:3001
AUTH_SECRET=replace_with_strong_staging_secret
PORT=3000
# Staging local usa NODE_ENV=production para reproduzir runtime, mas publica em localhost.
ALLOW_LOCALHOST_RUNTIME_URLS=1

# ---------- Required: Docker Compose infrastructure ----------
POSTGRES_USER=ants_staging
POSTGRES_PASSWORD=replace_with_strong_staging_db_password
POSTGRES_DB=ants_erp_staging
DATABASE_URL=postgresql://ants_staging:replace_with_strong_staging_db_password@postgres:5432/ants_erp_staging?schema=public
REDIS_URL=redis://redis:6379

# ---------- Required: published local port ----------
STAGING_WEB_PORT=3001

# ---------- Optional: defaults ----------
DEFAULT_LOCALE=pt-MZ
DEFAULT_CURRENCY=MZN
DEFAULT_TIMEZONE=Africa/Maputo

# ---------- Optional: production proxy only ----------
# Staging Compose does not start Caddy or publish 80/443.
DOMAIN=staging.example.co.mz

# ---------- Optional: future integrations ----------
STORAGE_ENDPOINT=
STORAGE_BUCKET=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
