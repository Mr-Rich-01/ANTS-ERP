# ANTS ERP — Exemplo de variáveis de ambiente (monólito Next.js)
# Copiar para `.env` e preencher. NUNCA commitar `.env` com segredos reais.

# ---------- Ambiente ----------
NODE_ENV=development

# ---------- Aplicação ----------
APP_URL=http://localhost:3000

# ---------- Autenticação (Auth.js) ----------
AUTH_URL=http://localhost:3000
# Gerar com: openssl rand -base64 33  (ou: npx auth secret)
AUTH_SECRET=changeme_auth_secret

# ---------- Base de dados (PostgreSQL) ----------
POSTGRES_USER=ants
POSTGRES_PASSWORD=ants_dev_password
POSTGRES_DB=ants_erp
DATABASE_URL=postgresql://ants:ants_dev_password@localhost:5432/ants_erp?schema=public

# ---------- Redis (cache + filas BullMQ) ----------
REDIS_URL=redis://localhost:6379

# ---------- Localização padrão ----------
DEFAULT_LOCALE=pt-MZ
DEFAULT_CURRENCY=MZN
DEFAULT_TIMEZONE=Africa/Maputo

# ---------- Produção / Deploy ----------
DOMAIN=erp.exemplo.co.mz
PORT=3000
BUILD_STANDALONE=
# Apenas para staging/local em NODE_ENV=production com URL localhost.
ALLOW_LOCALHOST_RUNTIME_URLS=

# ---------- Armazenamento de ficheiros (S3-compatível) - fase futura ----------
STORAGE_ENDPOINT=
STORAGE_BUCKET=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=

# ---------- Email (SMTP) — fases seguintes ----------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
