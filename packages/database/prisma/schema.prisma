// ANTS ERP — Esquema Prisma (Fase 0: fundação multiempresa + auth)
// Os módulos de negócio (clientes, stock, vendas, contabilidade, RH...) são
// adicionados nas fases seguintes. Aqui ficam as entidades transversais.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// Plataforma / Multiempresa
// ─────────────────────────────────────────────────────────────

model Company {
  id             String        @id @default(cuid())
  legalName      String
  tradeName      String?
  nuit           String?
  email          String?
  phone          String?
  status         CompanyStatus @default(ACTIVE)
  // Localização padrão (configurável por empresa)
  currency       String        @default("MZN")
  currencySymbol String        @default("MT")
  timezone       String        @default("Africa/Maputo")
  locale         String        @default("pt-MZ")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  branches             Branch[]
  settings             CompanySettings?
  users                User[]
  roles                Role[]
  auditLogs            AuditLog[]
  customers            Customer[]
  suppliers            Supplier[]
  products             Product[]
  warehouses           Warehouse[]
  stockLevels          StockLevel[]
  stockMovements       StockMovement[]
  purchaseReceipts     PurchaseReceipt[]
  purchaseReceiptItems PurchaseReceiptItem[]
  invoices             Invoice[]
  invoiceLines         InvoiceLine[]
  payments             Payment[]
  documentCounters     DocumentCounter[]
  purchaseOrders       PurchaseOrder[]
  purchaseOrderLines   PurchaseOrderLine[]
  supplierPayments     SupplierPayment[]
  treasuryAccounts     TreasuryAccount[]
  treasuryMovements    TreasuryMovement[]
  fiscalYears          FiscalYear[]
  accountingPeriods    AccountingPeriod[]
  ledgerAccounts       LedgerAccount[]
  accountingJournals   AccountingJournal[]
  journalEntries       JournalEntry[]
  journalEntryLines    JournalEntryLine[]
  accountingMappings   AccountingMapping[]
  operationIdempotency OperationIdempotency[]

  @@index([status])
  @@map("companies")
}

model CompanySettings {
  id             String   @id @default(cuid())
  companyId      String   @unique
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  // JSON flexível para taxas, séries documentais, rodapés, config de stock/contabilidade/salários
  fiscal         Json?
  documentSeries Json?
  branding       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("company_settings")
}

model Branch {
  id        String       @id @default(cuid())
  companyId String
  company   Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  code      String
  name      String
  address   String?
  phone     String?
  status    RecordStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  userBranches UserBranch[]
  warehouses   Warehouse[]

  @@unique([companyId, code])
  @@index([companyId])
  @@map("branches")
}

// ─────────────────────────────────────────────────────────────
// Utilizadores / RBAC
// ─────────────────────────────────────────────────────────────

model User {
  id                 String       @id @default(cuid())
  companyId          String? // null = Super Administrador da Plataforma
  company            Company?     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  email              String
  passwordHash       String
  name               String
  isPlatformAdmin    Boolean      @default(false)
  mustChangePassword Boolean      @default(true)
  status             RecordStatus @default(ACTIVE)
  lastLoginAt        DateTime?
  failedLoginCount   Int          @default(0)
  lockedUntil        DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  userRoles    UserRole[]
  userBranches UserBranch[]
  sessions     Session[]

  @@unique([companyId, email])
  @@index([companyId])
  @@index([email])
  @@map("users")
}

model Role {
  id          String   @id @default(cuid())
  companyId   String? // null = perfil de sistema (template global)
  company     Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("roles")
}

model Permission {
  id          String  @id @default(cuid())
  key         String  @unique // ex.: "sales.create", "accounting.post"
  description String?
  module      String // ex.: "sales", "accounting"

  rolePermissions RolePermission[]

  @@index([module])
  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model UserBranch {
  userId   String
  branchId String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@id([userId, branchId])
  @@index([branchId])
  @@map("user_branches")
}

// ─────────────────────────────────────────────────────────────
// Sessões / Auditoria
// ─────────────────────────────────────────────────────────────

model Session {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash String // nunca guardar o token em claro
  ipAddress        String?
  userAgent        String?
  expiresAt        DateTime
  revokedAt        DateTime?
  lastActivityAt   DateTime  @default(now())
  createdAt        DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model AuditLog {
  id        String   @id @default(cuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  branchId  String?
  userId    String?
  action    String // ex.: "invoice.issue"
  entity    String // ex.: "Invoice"
  entityId  String?
  oldValues Json?
  newValues Json?
  reason    String?
  ipAddress String?
  userAgent String?
  result    String? // "success" | "failure"
  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────────
// CRM — Clientes (Fase 2)
// ─────────────────────────────────────────────────────────────

model Customer {
  id              String       @id @default(cuid())
  companyId       String
  company         Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name            String
  type            CustomerType @default(COMPANY)
  nuit            String?
  email           String?
  phone           String?
  address         String?
  province        String?
  district        String?
  /// Limite de crédito concedido (MZN).
  creditLimit     Decimal      @default(0) @db.Decimal(14, 2)
  /// Saldo de conta-corrente: > 0 deve à empresa; < 0 saldo a favor.
  balance         Decimal      @default(0) @db.Decimal(14, 2)
  paymentTermDays Int          @default(0)
  segment         String?
  status          RecordStatus @default(ACTIVE)
  notes           String?
  createdBy       String?
  updatedBy       String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  invoices     Invoice[]
  payments     Payment[]
  journalLines JournalEntryLine[]

  @@unique([companyId, nuit])
  @@unique([companyId, id])
  @@index([companyId])
  @@index([companyId, status])
  @@index([name])
  @@map("customers")
}

// ─────────────────────────────────────────────────────────────
// Fornecedores (Fase 3)
// ─────────────────────────────────────────────────────────────

model Supplier {
  id              String       @id @default(cuid())
  companyId       String
  company         Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name            String
  type            SupplierType @default(COMPANY)
  nuit            String?
  email           String?
  phone           String?
  address         String?
  province        String?
  district        String?
  /// Limite de crédito concedido pelo fornecedor (MZN).
  creditLimit     Decimal      @default(0) @db.Decimal(14, 2)
  /// Saldo de conta-corrente: > 0 a empresa deve ao fornecedor (a pagar); < 0 adiantamento.
  balance         Decimal      @default(0) @db.Decimal(14, 2)
  paymentTermDays Int          @default(0)
  category        String?
  status          RecordStatus @default(ACTIVE)
  notes           String?
  createdBy       String?
  updatedBy       String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  purchaseOrders   PurchaseOrder[]
  purchaseReceipts PurchaseReceipt[]
  payments         SupplierPayment[]
  journalLines     JournalEntryLine[]

  @@unique([companyId, nuit])
  @@unique([companyId, id])
  @@index([companyId])
  @@index([companyId, status])
  @@index([name])
  @@map("suppliers")
}

// ─────────────────────────────────────────────────────────────
// Produtos & Stock (Fase 4)
// ─────────────────────────────────────────────────────────────

model Product {
  id        String       @id @default(cuid())
  companyId String
  company   Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sku       String
  name      String
  category  String?
  brand     String?
  unit      String       @default("un")
  /// Preço de venda unitário (MZN, IVA incl.).
  salePrice Decimal      @default(0) @db.Decimal(14, 2)
  /// Custo médio ponderado (MZN).
  avgCost   Decimal      @default(0) @db.Decimal(14, 2)
  /// Taxa de IVA aplicável (%).
  taxRate   Decimal      @default(16) @db.Decimal(5, 2)
  /// Stock mínimo (alerta de reposição).
  minStock  Int          @default(0)
  barcode   String?
  status    RecordStatus @default(ACTIVE)
  notes     String?
  createdBy String?
  updatedBy String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  stockLevels          StockLevel[]
  movements            StockMovement[]
  invoiceLines         InvoiceLine[]
  purchaseOrderLines   PurchaseOrderLine[]
  purchaseReceiptItems PurchaseReceiptItem[]

  @@unique([companyId, sku])
  @@unique([companyId, id])
  @@index([companyId])
  @@index([companyId, status])
  @@index([name])
  @@map("products")
}

model Warehouse {
  id        String       @id @default(cuid())
  companyId String
  company   Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branchId  String?
  branch    Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  code      String
  name      String
  status    RecordStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  stockLevels      StockLevel[]
  movements        StockMovement[]
  invoices         Invoice[]
  purchaseOrders   PurchaseOrder[]
  purchaseReceipts PurchaseReceipt[]

  @@unique([companyId, code])
  @@unique([companyId, id])
  @@index([companyId])
  @@map("warehouses")
}

model StockLevel {
  id          String    @id @default(cuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  quantity    Int       @default(0)
  updatedAt   DateTime  @updatedAt

  @@unique([productId, warehouseId])
  @@index([companyId])
  @@index([companyId, warehouseId])
  @@map("stock_levels")
}

model StockMovement {
  id                String            @id @default(cuid())
  companyId         String
  company           Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  productId         String
  product           Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouseId       String
  warehouse         Warehouse         @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  invoiceId         String?
  invoice           Invoice?          @relation(fields: [companyId, invoiceId], references: [companyId, id], onDelete: Restrict)
  purchaseReceiptId String?
  purchaseReceipt   PurchaseReceipt?  @relation(fields: [companyId, purchaseReceiptId], references: [companyId, id], onDelete: Restrict)
  reversesId        String?
  reverses          StockMovement?    @relation("StockMovementReversal", fields: [companyId, reversesId], references: [companyId, id], onDelete: Restrict)
  reversedBy        StockMovement?    @relation("StockMovementReversal")
  type              StockMovementType
  /// Delta com sinal: > 0 entrada · < 0 saída/ajuste negativo.
  quantity          Int
  /// Saldo do produto no armazém após o movimento.
  balanceAfter      Int
  document          String?
  reason            String?
  createdBy         String?
  createdAt         DateTime          @default(now())

  @@unique([companyId, id])
  @@unique([companyId, reversesId])
  @@index([companyId, productId, createdAt])
  @@index([companyId, warehouseId])
  @@index([companyId, invoiceId])
  @@index([companyId, purchaseReceiptId])
  @@map("stock_movements")
}

// ─────────────────────────────────────────────────────────────
// Vendas & Facturação (Fase 5)
// ─────────────────────────────────────────────────────────────

model Invoice {
  id                 String         @id @default(cuid())
  companyId          String
  company            Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branchId           String?
  /// Número do documento (ex.: "FT 2026/0001"), único por empresa.
  number             String
  customerId         String
  customer           Customer       @relation(fields: [customerId], references: [id], onDelete: Restrict)
  /// Snapshot dos dados do cliente no momento da emissão.
  customerName       String
  customerNuit       String?
  warehouseId        String
  warehouse          Warehouse      @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  issueDate          DateTime       @default(now())
  dueDate            DateTime
  status             InvoiceStatus  @default(ISSUED)
  cancelledAt        DateTime?
  cancelledById      String?
  cancellationReason String?
  subtotal           Decimal        @db.Decimal(14, 2)
  discountTotal      Decimal        @db.Decimal(14, 2)
  taxableBase        Decimal        @db.Decimal(14, 2)
  taxTotal           Decimal        @db.Decimal(14, 2)
  total              Decimal        @db.Decimal(14, 2)
  amountPaid         Decimal        @default(0) @db.Decimal(14, 2)
  paymentMethod      PaymentMethod?
  notes              String?
  createdBy          String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  lines          InvoiceLine[]
  payments       Payment[]
  stockMovements StockMovement[]

  @@unique([companyId, number])
  @@unique([companyId, id])
  @@index([companyId, status])
  @@index([companyId, customerId])
  @@index([companyId, issueDate])
  @@map("invoices")
}

model InvoiceLine {
  id              String   @id @default(cuid())
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoiceId       String
  invoice         Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId       String?
  product         Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  sku             String?
  description     String
  unitPrice       Decimal  @db.Decimal(14, 2)
  quantity        Int
  discountPercent Decimal  @default(0) @db.Decimal(5, 2)
  taxRate         Decimal  @default(16) @db.Decimal(5, 2)
  /// Total da linha (líquido + imposto).
  total           Decimal  @db.Decimal(14, 2)

  @@index([companyId])
  @@index([invoiceId])
  @@map("invoice_lines")
}

model Payment {
  id             String        @id @default(cuid())
  companyId      String
  company        Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  /// Número do recibo (ex.: "REC 2026/0001"), único por empresa.
  number         String
  invoiceId      String?
  invoice        Invoice?      @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  customerId     String
  customer       Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  amount         Decimal       @db.Decimal(14, 2)
  method         PaymentMethod @default(CASH)
  status         PaymentStatus @default(ACTIVE)
  reversedAt     DateTime?
  reversedById   String?
  reversalReason String?
  paidAt         DateTime      @default(now())
  notes          String?
  createdBy      String?
  createdAt      DateTime      @default(now())

  @@unique([companyId, number])
  @@index([companyId, customerId])
  @@index([companyId, status])
  @@index([companyId, paidAt])
  @@map("payments")
}

model DocumentCounter {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  /// Chave da série (ex.: "FT-2026", "REC-2026", "OC-2026", "PG-2026").
  key       String
  value     Int     @default(0)

  @@unique([companyId, key])
  @@map("document_counters")
}

// ─────────────────────────────────────────────────────────────
// Compras (Fase 6)
// ─────────────────────────────────────────────────────────────

model PurchaseOrder {
  id            String         @id @default(cuid())
  companyId     String
  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branchId      String?
  /// Número (ex.: "OC 2026/0001"), único por empresa.
  number        String
  supplierId    String
  supplier      Supplier       @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  supplierName  String
  supplierNuit  String?
  /// Armazém de destino da recepção.
  warehouseId   String
  warehouse     Warehouse      @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  orderDate     DateTime       @default(now())
  expectedDate  DateTime?
  status        PurchaseStatus @default(SENT)
  subtotal      Decimal        @db.Decimal(14, 2)
  taxTotal      Decimal        @db.Decimal(14, 2)
  total         Decimal        @db.Decimal(14, 2)
  /// Valor já recebido (com imposto) — base da conta a pagar gerada.
  receivedValue Decimal        @default(0) @db.Decimal(14, 2)
  amountPaid    Decimal        @default(0) @db.Decimal(14, 2)
  notes         String?
  createdBy     String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  lines    PurchaseOrderLine[]
  payments SupplierPayment[]
  receipts PurchaseReceipt[]

  @@unique([companyId, number])
  @@unique([companyId, id])
  @@index([companyId, status])
  @@index([companyId, supplierId])
  @@index([companyId, orderDate])
  @@map("purchase_orders")
}

model PurchaseOrderLine {
  id          String        @id @default(cuid())
  companyId   String
  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  orderId     String
  order       PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product?      @relation(fields: [productId], references: [id], onDelete: SetNull)
  sku         String?
  description String
  unitCost    Decimal       @db.Decimal(14, 2)
  quantity    Int
  receivedQty Int           @default(0)
  taxRate     Decimal       @default(16) @db.Decimal(5, 2)
  total       Decimal       @db.Decimal(14, 2)

  receiptItems PurchaseReceiptItem[]

  @@unique([companyId, id])
  @@index([companyId])
  @@index([orderId])
  @@map("purchase_order_lines")
}

model PurchaseReceipt {
  id              String                @id @default(cuid())
  companyId       String
  company         Company               @relation(fields: [companyId], references: [id], onDelete: Restrict)
  purchaseOrderId String
  purchaseOrder   PurchaseOrder         @relation(fields: [companyId, purchaseOrderId], references: [companyId, id], onDelete: Restrict)
  supplierId      String
  supplier        Supplier              @relation(fields: [companyId, supplierId], references: [companyId, id], onDelete: Restrict)
  warehouseId     String
  warehouse       Warehouse             @relation(fields: [companyId, warehouseId], references: [companyId, id], onDelete: Restrict)
  receiptNumber   String
  receiptDate     DateTime              @db.Date
  status          PurchaseReceiptStatus @default(ACTIVE)
  reversedAt      DateTime?
  reversedById    String?
  reversalReason  String?
  netAmount       Decimal               @db.Decimal(14, 2)
  taxAmount       Decimal               @db.Decimal(14, 2)
  totalAmount     Decimal               @db.Decimal(14, 2)
  notes           String?
  createdById     String?
  createdAt       DateTime              @default(now())

  items          PurchaseReceiptItem[]
  stockMovements StockMovement[]

  @@unique([companyId, receiptNumber])
  @@unique([companyId, id])
  @@index([companyId, purchaseOrderId])
  @@index([companyId, supplierId])
  @@index([companyId, status])
  @@index([companyId, receiptDate])
  @@map("purchase_receipts")
}

model PurchaseReceiptItem {
  id                  String            @id @default(cuid())
  companyId           String
  company             Company           @relation(fields: [companyId], references: [id], onDelete: Restrict)
  purchaseReceiptId   String
  purchaseReceipt     PurchaseReceipt   @relation(fields: [companyId, purchaseReceiptId], references: [companyId, id], onDelete: Restrict)
  purchaseOrderLineId String
  purchaseOrderLine   PurchaseOrderLine @relation(fields: [companyId, purchaseOrderLineId], references: [companyId, id], onDelete: Restrict)
  productId           String
  product             Product           @relation(fields: [companyId, productId], references: [companyId, id], onDelete: Restrict)
  quantity            Int
  unitCost            Decimal           @db.Decimal(14, 2)
  taxRate             Decimal           @default(0) @db.Decimal(5, 2)
  netAmount           Decimal           @db.Decimal(14, 2)
  taxAmount           Decimal           @db.Decimal(14, 2)
  totalAmount         Decimal           @db.Decimal(14, 2)

  @@unique([companyId, purchaseReceiptId, purchaseOrderLineId])
  @@index([companyId, purchaseOrderLineId])
  @@index([companyId, productId])
  @@map("purchase_receipt_items")
}

model SupplierPayment {
  id              String                @id @default(cuid())
  companyId       String
  company         Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  /// Número (ex.: "PG 2026/0001"), único por empresa.
  number          String
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder?        @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  supplierId      String
  supplier        Supplier              @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  amount          Decimal               @db.Decimal(14, 2)
  method          PaymentMethod         @default(TRANSFER)
  status          SupplierPaymentStatus @default(ACTIVE)
  reversedAt      DateTime?
  reversedById    String?
  reversalReason  String?
  paidAt          DateTime              @default(now())
  notes           String?
  createdBy       String?
  createdAt       DateTime              @default(now())

  @@unique([companyId, number])
  @@index([companyId, supplierId])
  @@index([companyId, status])
  @@index([companyId, paidAt])
  @@map("supplier_payments")
}

// ─────────────────────────────────────────────────────────────
// Tesouraria & Bancos (Fase 7)
// ─────────────────────────────────────────────────────────────

model TreasuryAccount {
  id             String              @id @default(cuid())
  companyId      String
  company        Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name           String
  type           TreasuryAccountType @default(BANK)
  /// Nº de conta / IBAN / nº de telemóvel (carteira), conforme o tipo.
  reference      String?
  currency       String              @default("MZN")
  openingBalance Decimal             @default(0) @db.Decimal(14, 2)
  balance        Decimal             @default(0) @db.Decimal(14, 2)
  /// Se a conta permite saldo negativo (descoberto). Caixa/carteiras: false por omissão.
  allowNegative  Boolean             @default(false)
  status         RecordStatus        @default(ACTIVE)
  createdBy      String?
  updatedBy      String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  /// Conta do razão associada (1:1 por empresa) — base da contabilização integrada (8c).
  /// Resolvida sempre por ledgerAccountId, nunca por código/systemKey.
  ledgerAccountId String?
  ledgerAccount   LedgerAccount? @relation(fields: [companyId, ledgerAccountId], references: [companyId, id], onDelete: Restrict)

  movements    TreasuryMovement[]
  journalLines JournalEntryLine[]

  @@unique([companyId, name])
  @@unique([companyId, id])
  @@unique([companyId, ledgerAccountId])
  @@index([companyId])
  @@map("treasury_accounts")
}

model TreasuryMovement {
  id                   String                 @id @default(cuid())
  companyId            String
  company              Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  accountId            String
  account              TreasuryAccount        @relation(fields: [accountId], references: [id], onDelete: Cascade)
  flow                 TreasuryFlow
  amount               Decimal                @db.Decimal(14, 2)
  /// Saldo da conta após o movimento.
  balanceAfter         Decimal                @db.Decimal(14, 2)
  /// Categoria: Recibo, Pagamento, Depósito, Levantamento, Transferência, Despesa, Receita.
  category             String
  description          String?
  document             String?
  /// Conta de contrapartida (em transferências).
  counterpartAccountId String?
  /// Liga os dois movimentos de uma mesma transferência.
  transferId           String?
  /// Origem do movimento: MANUAL, RECEIPT, SUPPLIER_PAYMENT, TRANSFER, REVERSAL.
  source               String                 @default("MANUAL")
  /// Idempotência: tipo/id do documento de origem e finalidade do movimento.
  sourceType           String?
  sourceId             String?
  movementPurpose      String?
  /// Estado: ACTIVE (em vigor) ou REVERSED (estornado por outro movimento).
  status               TreasuryMovementStatus @default(ACTIVE)
  /// Estorno: este movimento reverte o original (reversesId) / foi revertido por (reversedById).
  reversesId           String?                @unique
  reverses             TreasuryMovement?      @relation("TreasuryReversal", fields: [reversesId], references: [id])
  reversedBy           TreasuryMovement?      @relation("TreasuryReversal")
  reversalReason       String?
  createdBy            String?
  occurredAt           DateTime               @default(now())
  createdAt            DateTime               @default(now())

  @@unique([companyId, sourceType, sourceId, movementPurpose])
  @@index([companyId, accountId, occurredAt])
  @@index([companyId, status])
  @@index([companyId, occurredAt])
  @@index([transferId])
  @@map("treasury_movements")
}

