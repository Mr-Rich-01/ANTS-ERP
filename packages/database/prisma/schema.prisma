// ─────────────────────────────────────────────────────────────
// Contabilidade (Fase 8a)
//
// Isolamento multiempresa reforçado por FKs COMPOSTAS [companyId, id]:
// nenhuma relação contabilística consegue referenciar dados de outra
// empresa, mesmo por SQL directo ou falha do scoping aplicacional.
// Relações com Company em `Restrict`: o histórico financeiro nunca
// desaparece por cascata (a empresa é soft-deleted via `status`).
// ─────────────────────────────────────────────────────────────

model FiscalYear {
  id          String           @id @default(cuid())
  companyId   String
  company     Company          @relation(fields: [companyId], references: [id], onDelete: Restrict)
  name        String
  startDate   DateTime         @db.Date
  endDate     DateTime         @db.Date
  status      FiscalYearStatus @default(OPEN)
  isCurrent   Boolean          @default(false)
  createdById String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  periods        AccountingPeriod[]
  journalEntries JournalEntry[]
  // + raw SQL: CHECK start<=end · EXCLUDE sem sobreposição · índice parcial "um corrente"

  @@unique([companyId, name])
  @@unique([companyId, id])
  @@index([companyId])
  @@index([companyId, status])
  @@map("fiscal_years")
}

model AccountingPeriod {
  id           String                 @id @default(cuid())
  companyId    String
  company      Company                @relation(fields: [companyId], references: [id], onDelete: Restrict)
  fiscalYearId String
  fiscalYear   FiscalYear             @relation(fields: [companyId, fiscalYearId], references: [companyId, id], onDelete: Restrict)
  periodNumber Int
  code         String
  name         String
  startDate    DateTime               @db.Date
  endDate      DateTime               @db.Date
  status       AccountingPeriodStatus @default(OPEN)
  isAdjustment Boolean                @default(false)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  journalEntries JournalEntry[]
  // + raw SQL: CHECK start<=end · EXCLUDE sem sobreposição (excl. ajustamento)
  // contenção período⊆exercício validada no domínio 8b (CHECK não cruza tabelas)

  @@unique([companyId, code])
  @@unique([companyId, fiscalYearId, periodNumber])
  @@unique([companyId, id])
  @@index([companyId, fiscalYearId])
  @@index([companyId, status])
  @@map("accounting_periods")
}

model LedgerAccount {
  id              String            @id @default(cuid())
  companyId       String
  company         Company           @relation(fields: [companyId], references: [id], onDelete: Restrict)
  code            String
  name            String
  accountType     LedgerAccountType
  normalBalance   NormalBalance
  parentId        String?
  parent          LedgerAccount?    @relation("LedgerHierarchy", fields: [companyId, parentId], references: [companyId, id], onDelete: Restrict)
  children        LedgerAccount[]   @relation("LedgerHierarchy")
  level           Int               @default(1)
  isPosting       Boolean           @default(true)
  isActive        Boolean           @default(true)
  /// Só provisionamento/reparação idempotente do plano-base. NUNCA usado por
  /// lançamentos ou integrações — a fonte funcional é AccountingMapping.systemKey.
  provisioningKey String?
  description     String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  lines           JournalEntryLine[]
  mappings        AccountingMapping[]
  treasuryAccount TreasuryAccount?
  // + raw SQL: CHECK (level >= 1)

  @@unique([companyId, code])
  @@unique([companyId, provisioningKey])
  @@unique([companyId, id])
  @@index([companyId])
  @@index([companyId, accountType])
  @@index([companyId, parentId])
  @@index([companyId, isActive])
  @@map("ledger_accounts")
}

model AccountingJournal {
  id             String                @id @default(cuid())
  companyId      String
  company        Company               @relation(fields: [companyId], references: [id], onDelete: Restrict)
  code           String
  name           String
  journalType    AccountingJournalType
  sequencePrefix String?
  description    String?
  isActive       Boolean               @default(true)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  journalEntries JournalEntry[]

  @@unique([companyId, code])
  @@unique([companyId, id])
  @@index([companyId])
  @@index([companyId, journalType])
  @@map("accounting_journals")
}

model JournalEntry {
  id                 String             @id @default(cuid())
  companyId          String
  company            Company            @relation(fields: [companyId], references: [id], onDelete: Restrict)
  fiscalYearId       String
  fiscalYear         FiscalYear         @relation(fields: [companyId, fiscalYearId], references: [companyId, id], onDelete: Restrict)
  accountingPeriodId String
  accountingPeriod   AccountingPeriod   @relation(fields: [companyId, accountingPeriodId], references: [companyId, id], onDelete: Restrict)
  journalId          String
  journal            AccountingJournal  @relation(fields: [companyId, journalId], references: [companyId, id], onDelete: Restrict)
  entryNumber        String
  entryDate          DateTime           @db.Date
  postingDate        DateTime?          @db.Date
  description        String
  reference          String?
  status             JournalEntryStatus @default(DRAFT)
  /// Origem + finalidade (idempotência fina): NULL nos três = lançamento manual.
  sourceType         String?
  sourceId           String?
  accountingEvent    String?
  /// Estorno: self-relation COMPOSTA, anti cross-company; estornado no máx. uma vez.
  reversalOfId       String?
  reversalOf         JournalEntry?      @relation("JournalReversal", fields: [companyId, reversalOfId], references: [companyId, id], onDelete: Restrict)
  reversedBy         JournalEntry?      @relation("JournalReversal")
  /// Materializados a partir das linhas (fonte de verdade) na transacção do 8b.
  totalDebit         Decimal            @default(0) @db.Decimal(14, 2)
  totalCredit        Decimal            @default(0) @db.Decimal(14, 2)
  postedAt           DateTime?
  postedById         String?
  createdById        String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  lines JournalEntryLine[]
  // + raw SQL: CHECK totais>=0 · CHECK origem all-null-or-all-set

  @@unique([companyId, fiscalYearId, journalId, entryNumber])
  @@unique([companyId, id])
  @@unique([companyId, reversalOfId])
  @@unique([companyId, sourceType, sourceId, accountingEvent])
  @@index([companyId, status])
  @@index([companyId, entryDate])
  @@index([companyId, postingDate])
  @@index([companyId, journalId])
  @@index([companyId, accountingPeriodId])
  @@index([companyId, fiscalYearId])
  @@index([companyId, sourceType, sourceId])
  @@map("journal_entries")
}

model JournalEntryLine {
  id                String           @id @default(cuid())
  companyId         String
  company           Company          @relation(fields: [companyId], references: [id], onDelete: Restrict)
  journalEntryId    String
  journalEntry      JournalEntry     @relation(fields: [companyId, journalEntryId], references: [companyId, id], onDelete: Restrict)
  ledgerAccountId   String
  ledgerAccount     LedgerAccount    @relation(fields: [companyId, ledgerAccountId], references: [companyId, id], onDelete: Restrict)
  description       String?
  debit             Decimal          @default(0) @db.Decimal(14, 2)
  credit            Decimal          @default(0) @db.Decimal(14, 2)
  lineNumber        Int
  /// Dimensões analíticas opcionais — FKs COMPOSTAS anti cross-company.
  customerId        String?
  customer          Customer?        @relation(fields: [companyId, customerId], references: [companyId, id], onDelete: Restrict)
  supplierId        String?
  supplier          Supplier?        @relation(fields: [companyId, supplierId], references: [companyId, id], onDelete: Restrict)
  treasuryAccountId String?
  treasuryAccount   TreasuryAccount? @relation(fields: [companyId, treasuryAccountId], references: [companyId, id], onDelete: Restrict)
  createdAt         DateTime         @default(now())
  // + raw SQL: CHECK débito XOR crédito (>0) · CHECK nonneg · CHECK lineNumber>0

  @@unique([companyId, journalEntryId, lineNumber])
  @@index([companyId])
  @@index([companyId, journalEntryId])
  @@index([companyId, ledgerAccountId, createdAt])
  @@map("journal_entry_lines")
}

model AccountingMapping {
  id              String        @id @default(cuid())
  companyId       String
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  /// Única configuração funcional consultada pelo domínio/integrações.
  systemKey       String
  ledgerAccountId String
  ledgerAccount   LedgerAccount @relation(fields: [companyId, ledgerAccountId], references: [companyId, id], onDelete: Restrict)
  description     String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([companyId, systemKey])
  @@index([companyId])
  @@map("accounting_mappings")
}

enum FiscalYearStatus {
  OPEN
  CLOSED
  LOCKED
}

enum AccountingPeriodStatus {
  OPEN
  CLOSED
  LOCKED
}

enum LedgerAccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum NormalBalance {
  DEBIT
  CREDIT
}

enum AccountingJournalType {
  GENERAL
  SALES
  PURCHASES
  CASH
  BANK
  PAYROLL
  ADJUSTMENT
  OPENING
}

enum JournalEntryStatus {
  DRAFT
  POSTED
  REVERSED
}

// ─────────────────────────────────────────────────────────────
// Idempotência operacional (Fase 8c.2a)
//
// Impede a CRIAÇÃO duplicada do documento (nível operacional) — complementa a
// idempotência contabilística por (companyId, sourceType, sourceId, accountingEvent).
// A chave é fornecida pelo cliente (estável por tentativa); o fingerprint é calculado
// no servidor a partir do payload validado. Sem TTL/limpeza automática nesta fase.
// ─────────────────────────────────────────────────────────────

enum OperationIdempotencyScope {
  INVOICE_CREATE
  CUSTOMER_PAYMENT_CREATE
  PURCHASE_RECEIPT_CREATE
  SUPPLIER_PAYMENT_CREATE
  INVOICE_CANCEL
  CUSTOMER_PAYMENT_REVERSE
  SUPPLIER_PAYMENT_REVERSE
  PURCHASE_RECEIPT_REVERSE
  TREASURY_TRANSFER_REVERSE
  MANUAL_TREASURY_REVERSE
}

model OperationIdempotency {
  id                 String                    @id @default(cuid())
  companyId          String
  company            Company                   @relation(fields: [companyId], references: [id], onDelete: Restrict)
  scope              OperationIdempotencyScope
  idempotencyKey     String
  /// Fingerprint versionado do payload (ex.: "v1:<sha256>").
  requestFingerprint String
  resourceType       String?
  resourceId         String?
  /// Actor (escalar, como AuditLog.userId — sem FK).
  createdById        String?
  createdAt          DateTime                  @default(now())
  completedAt        DateTime?

  @@unique([companyId, scope, idempotencyKey])
  @@index([companyId, resourceType, resourceId])
  @@map("operation_idempotency")
}
