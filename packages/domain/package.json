{
  "name": "@ants/domain",
  "version": "0.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts accounting.integration accounting.c1.integration accounting.c2a.integration accounting.c2.integration accounting.c3.integration accounting.cogs.integration accounting.credit-note-cancellation.integration accounting.inventory-regularization.integration accounting.reports.integration accounting.statements.integration treasury-reversals.integration accounting.reversal-foundation.integration accounting.customer-payment-reversal.integration accounting.invoice-cancellation.integration accounting.supplier-payment-reversal.integration accounting.purchase-receipt-reversal.integration accounting.treasury-transfer-reversal.integration accounting.reversals-uat.integration",
    "test:integration:c1": "vitest run --config vitest.integration.config.ts accounting.c1.integration",
    "test:integration:c2": "vitest run --config vitest.integration.config.ts accounting.c2.integration",
    "test:integration:c2a": "vitest run --config vitest.integration.config.ts accounting.c2a.integration",
    "test:integration:c3": "vitest run --config vitest.integration.config.ts accounting.c3.integration",
    "test:integration:cogs": "vitest run --config vitest.integration.config.ts accounting.cogs.integration",
    "test:integration:credit-note-cancellation": "vitest run --config vitest.integration.config.ts accounting.credit-note-cancellation.integration",
    "test:integration:inventory-regularization": "vitest run --config vitest.integration.config.ts accounting.inventory-regularization.integration",
    "test:integration:accounting-reports": "vitest run --config vitest.integration.config.ts accounting.reports.integration",
    "test:integration:accounting-statements": "vitest run --config vitest.integration.config.ts accounting.statements.integration",
    "test:integration:customer-payment-reversal": "vitest run --config vitest.integration.config.ts accounting.customer-payment-reversal.integration",
    "test:integration:invoice-cancellation": "vitest run --config vitest.integration.config.ts accounting.invoice-cancellation.integration",
    "test:integration:supplier-payment-reversal": "vitest run --config vitest.integration.config.ts accounting.supplier-payment-reversal.integration",
    "test:integration:purchase-receipt-reversal": "vitest run --config vitest.integration.config.ts accounting.purchase-receipt-reversal.integration",
    "test:integration:treasury-transfer-reversal": "vitest run --config vitest.integration.config.ts accounting.treasury-transfer-reversal.integration",
    "test:integration:reversals-uat": "vitest run --config vitest.integration.config.ts accounting.reversals-uat.integration",
    "test:integration:auth-company-selection": "vitest run --config vitest.integration.config.ts auth.company-selection.integration",
    "test:integration:pos": "vitest run --config vitest.integration.config.ts pos.integration",
    "test:integration:reports": "vitest run --config vitest.integration.config.ts reports.integration",
    "test:integration:company-profile": "vitest run --config vitest.integration.config.ts company-profile.integration",
    "test:integration:treasury-cash-closing": "vitest run --config vitest.integration.config.ts treasury.cash-closing.integration",
    "test:integration:documents": "vitest run --config vitest.integration.config.ts commercial-documents.integration",
    "test:integration:invoice-drafts": "vitest run --config vitest.integration.config.ts invoices.drafts.integration",
    "test:integration:purchases-approval": "vitest run --config vitest.integration.config.ts purchases.approval.integration",
    "test:integration:products-initial-stock": "vitest run --config vitest.integration.config.ts products.initial-stock.integration",
    "test:integration:stock-counts": "vitest run --config vitest.integration.config.ts stock-counts.integration",
    "test:integration:reversal-all": "vitest run --config vitest.integration.config.ts accounting.customer-payment-reversal.integration accounting.invoice-cancellation.integration accounting.supplier-payment-reversal.integration accounting.purchase-receipt-reversal.integration accounting.treasury-transfer-reversal.integration accounting.reversals-uat.integration"
  },
  "dependencies": {
    "@ants/database": "workspace:*",
    "@ants/shared": "workspace:*",
    "@node-rs/argon2": "^2.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@ants/config": "workspace:*",
    "@types/node": "^22.7.4",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
