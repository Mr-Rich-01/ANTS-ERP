{
  "name": "ants-erp",
  "version": "0.0.0",
  "private": true,
  "description": "ANTS ERP — sistema ERP modular, multiempresa, pt-MZ",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "pnpm --filter @ants/database generate",
    "db:migrate": "pnpm --filter @ants/database migrate:dev",
    "db:migrate:deploy": "pnpm --filter @ants/database migrate:deploy",
    "db:seed": "pnpm --filter @ants/database seed",
    "test:integration:accounting": "pnpm --filter @ants/domain test:integration",
    "test:integration:accounting:c1": "pnpm --filter @ants/domain test:integration:c1",
    "test:integration:accounting:c2": "pnpm --filter @ants/domain test:integration:c2",
    "test:integration:accounting:c2a": "pnpm --filter @ants/domain test:integration:c2a",
    "test:integration:accounting:c3": "pnpm --filter @ants/domain test:integration:c3",
    "test:integration:accounting:cogs": "pnpm --filter @ants/domain test:integration:cogs",
    "test:integration:accounting:reports": "pnpm --filter @ants/domain test:integration:accounting-reports",
    "test:integration:accounting:reversal:customer-payment": "pnpm --filter @ants/domain test:integration:customer-payment-reversal",
    "test:integration:accounting:reversal:invoice": "pnpm --filter @ants/domain test:integration:invoice-cancellation",
    "test:integration:accounting:reversal:supplier-payment": "pnpm --filter @ants/domain test:integration:supplier-payment-reversal",
    "test:integration:accounting:reversal:purchase-receipt": "pnpm --filter @ants/domain test:integration:purchase-receipt-reversal",
    "test:integration:accounting:reversal:treasury-transfer": "pnpm --filter @ants/domain test:integration:treasury-transfer-reversal",
    "test:integration:accounting:reversal:uat": "pnpm --filter @ants/domain test:integration:reversals-uat",
    "test:integration:accounting:reversal:all": "pnpm --filter @ants/domain test:integration:reversal-all",
    "test:integration:auth:company-selection": "pnpm --filter @ants/domain test:integration:auth-company-selection",
    "test:integration:security:production-hardening": "pnpm --filter @ants/shared test -- production-hardening && pnpm --filter @ants/database test -- production-hardening",
    "test:integration:pos": "pnpm --filter @ants/domain test:integration:pos",
    "test:integration:reports": "pnpm --filter @ants/domain test:integration:reports",
    "test:integration:treasury:cash-closing": "pnpm --filter @ants/domain test:integration:treasury-cash-closing",
    "test:integration:company-profile": "pnpm --filter @ants/domain test:integration:company-profile",
    "test:integration:documents": "pnpm --filter @ants/domain test:integration:documents",
    "test:integration:invoices:drafts": "pnpm --filter @ants/domain test:integration:invoice-drafts",
    "test:integration:purchases:approval": "pnpm --filter @ants/domain test:integration:purchases-approval",
    "test:integration:products:initial-stock": "pnpm --filter @ants/domain test:integration:products-initial-stock",
    "test:integration:stock:counts": "pnpm --filter @ants/domain test:integration:stock-counts",
    "docker:dev": "docker compose up -d postgres redis",
    "docker:build:web": "docker build -f apps/web/Dockerfile -t ants-erp-web:local .",
    "docker:build:worker": "docker build -f apps/worker/Dockerfile -t ants-erp-worker:local .",
    "docker:build": "pnpm docker:build:web && pnpm docker:build:worker",
    "docker:production:build": "docker compose -f docker-compose.production.yml build",
    "docker:staging:build": "docker compose --env-file .env.staging -f docker-compose.staging.yml build",
    "docker:staging:migrate": "docker compose --env-file .env.staging -f docker-compose.staging.yml --profile migration run --rm migrate",
    "docker:staging:up": "docker compose --env-file .env.staging -f docker-compose.staging.yml up -d web worker",
    "docker:staging:ps": "docker compose --env-file .env.staging -f docker-compose.staging.yml ps",
    "docker:staging:logs": "docker compose --env-file .env.staging -f docker-compose.staging.yml logs -f --tail=100 web worker",
    "docker:staging:down": "docker compose --env-file .env.staging -f docker-compose.staging.yml down",
    "ops:staging:backup": "node scripts/ops/staging-backup-db.mjs",
    "ops:staging:restore": "node scripts/ops/staging-restore-db.mjs",
    "ops:staging:backup:help": "node scripts/ops/staging-backup-db.mjs --help",
    "ops:staging:restore:help": "node scripts/ops/staging-restore-db.mjs --help"
  },
  "devDependencies": {
    "eslint": "^9.11.1",
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2"
  },
  "pnpm": {
    "overrides": {
      "ioredis": "5.10.1"
    }
  }
}
